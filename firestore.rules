rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function getUser(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      return signedIn() && getUser(request.auth.uid).role == 'admin';
    }

    function isTeacher() {
      return signedIn() && getUser(request.auth.uid).role == 'teacher';
    }

    function teacherSchoolId() {
      return getUser(request.auth.uid).schoolId;
    }

    match /schools/{schoolId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.ownerId
        && request.resource.data.schoolId == schoolId
        && request.resource.data.inviteCode == schoolId
        && request.resource.data.name is string
        && request.resource.data.ownerId is string;
      allow update, delete: if isAdmin() || (isTeacher() && resource.data.ownerId == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if signedIn()
        && (request.auth.uid == userId
          || isAdmin()
          || (isTeacher() && resource.data.schoolId == teacherSchoolId()));

      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role in ['teacher', 'pending']
        && request.resource.data.approved == (request.resource.data.role == 'teacher')
        && request.resource.data.mentorCertified == false
        && request.resource.data.assignedTeacher == null
        && (request.resource.data.schoolId == null || request.resource.data.role == 'pending')
        && request.resource.data.createdAt == request.resource.data.updatedAt;

      allow update: if isAdmin()
        || (request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.approved == resource.data.approved
          && request.resource.data.mentorCertified == resource.data.mentorCertified
          && request.resource.data.schoolId == resource.data.schoolId
          && request.resource.data.assignedTeacher == resource.data.assignedTeacher
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.createdAt == resource.data.createdAt)
        || (isTeacher()
          && resource.data.schoolId == teacherSchoolId()
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.schoolId == resource.data.schoolId
          && request.resource.data.assignedTeacher == request.auth.uid
          && request.resource.data.approved == true
          && request.resource.data.role in ['mentor', 'learner']
          && request.resource.data.mentorCertified == resource.data.mentorCertified
          && request.resource.data.createdAt == resource.data.createdAt);
    }

    match /pendingStudents/{studentId} {
      allow read: if signedIn()
        && (request.auth.uid == studentId
          || isAdmin()
          || (isTeacher() && resource.data.schoolId == teacherSchoolId()));

      allow create: if signedIn()
        && request.auth.uid == studentId
        && request.resource.data.studentId == studentId
        && request.resource.data.schoolId is string
        && request.resource.data.studentName is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.status == 'pending';

      allow update: if isAdmin()
        || (isTeacher()
          && resource.data.schoolId == teacherSchoolId()
          && request.resource.data.status in ['approved', 'rejected']
          && request.resource.data.processedAt == request.time);
    }

    match /certificates/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.courseId == 'responsible-ai'
        && request.resource.data.certified == true;
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
